# Vendored Rockie platform skills (MIT, Synthetic Sciences) — re-pull with
# `rockie skill pull <name> --out .claude/skills/<name>`. Dependencies, not
# our source; kept out of the repo so what's committed here is ours.
.claude/skills/grpo-rl-training/
.claude/skills/trl-fine-tuning/
.claude/skills/verl/
.claude/skills/openrlhf/
.claude/skills/simpo/
.claude/skills/unsloth/
.claude/skills/lm-evaluation-harness/
.claude/skills/llm-as-judge-evaluation/

# ─── rockie harness block — managed by install.sh ────────────────────
# Do not edit between the BEGIN and END markers. install.sh will re-merge
# this block on upgrades. Rules outside the markers are yours and are
# preserved.

# BEGIN rockie
# Stray git-internals backups — never commit raw git internals
# (e.g. `cp -r .git .git.backup-x` during a repo split/migration).
.git.backup*/
.git.bak*/

# Harness runtime — per-project state, never commit
.claude/memory/workflow.db
.claude/memory/workflow.db-*
.claude/memory/hook.log*
.claude/memory/ntfy_last_seen
.claude/memory/zcm_events.jsonl
.claude/memory/autopilot_events.jsonl
.claude/memory/autopilot.log
.claude/.state/
.team-runs/

# Shell-sourced / secret per-project configs — never commit
.claude/autopilot.conf
.claude/budget.toml
.claude/project_id
.claude/settings.local.json

# Agent scratch — drafts, temp plots, in-progress notes
.claude/_local/

# Secrets — defense-in-depth even if you have them elsewhere
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
id_ed25519*
id_ecdsa*
.netrc
credentials.json
credentials.yaml
secrets/
*.secret
service-account*.json

# ML artifacts — training outputs don't belong in the repo
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin
*.npz
checkpoints/
wandb/
mlruns/

# User-confidential — see docs/install.md "where things go"
_private/
**/_private/
docs/_internal/
**/*.private.md
NOTES_PRIVATE*

# Researcher taste corpus — personal, like .env. Opt-in to commit by
# removing the `.rockie/taste/` line below. Drafts and archives stay
# ignored even if the user opts in to committing the corpus itself.
.rockie/taste/
.rockie/taste/.draft.json
.rockie/taste/.archive/
# END rockie

# Research direction / researcher context — not published while the
# project is pre-commercialization. Remove this line to publish.
CLAUDE.md

# Reference-corpus PDFs — downloaded for reading only. Third-party
# copyrighted papers; never commit. Citations/summaries live in
# references/*.md and references/papers.bib instead.
references/pdfs/
docs/private/
