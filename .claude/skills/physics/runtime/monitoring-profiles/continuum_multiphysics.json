{
  "profile_id": "physics.continuum_multiphysics.v1",
  "domain": "physics",
  "family": "continuum_multiphysics",
  "expected_duration_class": "medium",
  "heartbeat": {"min_threshold_seconds": 60, "cadence_seconds": 300, "max_gap_seconds": 1800},
  "metrics": [
    {"name": "physical_time", "unit": "s", "kind": "timeseries", "source": "log", "required": false},
    {"name": "iteration", "unit": "count", "kind": "timeseries", "source": "log", "required": true},
    {"name": "continuity_residual", "unit": "arb", "kind": "timeseries", "source": "parser", "required": true},
    {"name": "cfl", "unit": "1", "kind": "timeseries", "source": "parser", "required": false},
    {"name": "mesh_quality_warnings", "unit": "count", "kind": "event", "source": "log", "required": false},
    {"name": "drag_force", "unit": "N", "kind": "timeseries", "source": "parser", "required": false},
    {"name": "boundary_condition_warnings", "unit": "count", "kind": "event", "source": "log", "required": true},
    {"name": "integrated_flux", "unit": "kg/s", "kind": "timeseries", "source": "parser", "required": true}
  ],
  "panels": [{"id": "solver", "title": "Solver Health", "metric_names": ["iteration", "continuity_residual", "cfl", "drag_force", "boundary_condition_warnings", "integrated_flux"]}],
  "red_flags": [{"id": "solver_divergence", "severity": "stop", "condition": "residuals increase repeatedly, CFL blows up, or boundary-condition warning is fatal", "recommended_action": "preserve case and review mesh, timestep, schemes, and boundary conditions"}],
  "stop_policy": {"default_action": "warn", "requires_budget_recheck_for_relaunch": true},
  "redaction": {"apply_common_redaction": true, "sensitive_fields": ["license_server", "module_path"]}
}
