{
  "profile_id": "physics.plasma_pic.v1",
  "domain": "physics",
  "family": "plasma_pic",
  "expected_duration_class": "hpc",
  "heartbeat": {"min_threshold_seconds": 60, "cadence_seconds": 300, "max_gap_seconds": 1800},
  "metrics": [
    {"name": "timestep", "unit": "count", "kind": "timeseries", "source": "log", "required": true},
    {"name": "particles_per_cell", "unit": "count", "kind": "gauge", "source": "artifact", "required": true},
    {"name": "field_energy", "unit": "J", "kind": "timeseries", "source": "parser", "required": true},
    {"name": "charge_conservation_warnings", "unit": "count", "kind": "event", "source": "log", "required": false},
    {"name": "courant_constraint", "unit": "1", "kind": "gauge", "source": "artifact", "required": true},
    {"name": "openpmd_freshness", "unit": "s", "kind": "gauge", "source": "artifact", "required": false}
  ],
  "panels": [{"id": "pic_health", "title": "PIC Health", "metric_names": ["timestep", "particles_per_cell", "field_energy", "charge_conservation_warnings", "openpmd_freshness"]}],
  "red_flags": [{"id": "courant_or_charge_violation", "severity": "stop", "condition": "Courant violation or charge/current conservation warning appears", "recommended_action": "stop and review grid spacing, timestep, particle shape, and boundary conditions"}],
  "stop_policy": {"default_action": "warn", "requires_budget_recheck_for_relaunch": true},
  "redaction": {"apply_common_redaction": true, "sensitive_fields": ["license_server", "module_path"]}
}
