{
  "profile_id": "physics.electronic_structure.v1",
  "domain": "physics",
  "family": "electronic_structure",
  "expected_duration_class": "medium",
  "heartbeat": {"min_threshold_seconds": 60, "cadence_seconds": 300, "max_gap_seconds": 1800},
  "metrics": [
    {"name": "scf_iteration", "unit": "count", "kind": "timeseries", "source": "log", "required": true},
    {"name": "total_energy", "unit": "Ry", "kind": "timeseries", "source": "parser", "required": true},
    {"name": "scf_residual", "unit": "Ry", "kind": "timeseries", "source": "parser", "required": true},
    {"name": "force_convergence", "unit": "Ry/bohr", "kind": "timeseries", "source": "parser", "required": false},
    {"name": "smearing_width", "unit": "Ry", "kind": "timeseries", "source": "parser", "required": false},
    {"name": "occupation_spread", "unit": "fraction", "kind": "timeseries", "source": "parser", "required": false},
    {"name": "smearing_occupancy_warnings", "unit": "count", "kind": "event", "source": "log", "required": true},
    {"name": "geometry_step", "unit": "count", "kind": "timeseries", "source": "log", "required": false},
    {"name": "wall_time_per_step", "unit": "s", "kind": "timeseries", "source": "log", "required": false}
  ],
  "panels": [{"id": "scf", "title": "SCF Convergence", "metric_names": ["scf_iteration", "scf_residual", "total_energy", "force_convergence", "smearing_width", "occupation_spread", "smearing_occupancy_warnings"]}],
  "red_flags": [{"id": "scf_nonconvergence", "severity": "stop", "condition": "SCF residual stagnates, max iteration is reached, or smearing/occupancy warnings are unresolved", "recommended_action": "preserve output and review smearing, cutoff, k-points, charge, and spin"}],
  "stop_policy": {"default_action": "warn", "requires_budget_recheck_for_relaunch": true},
